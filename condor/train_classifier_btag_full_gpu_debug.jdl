universe = vanilla
executable = train_classifier_btag_full_gpu_debug.sh

# Keep environment explicit; avoid getenv=true on LPC worker nodes.
environment = "PROJECT_DIR=/uscms/home/sdurgut1/nobackup/tthbb/ttHbb_SPANet OPTIONS_FILE=/uscms/home/sdurgut1/nobackup/tthbb/ttHbb_SPANet/options_files/ttHbb_fully_hadronic/classifier/options_file_Run2_Run3_sig_QCD_classifier_btag_full.json LOG_DIR=/uscms/home/sdurgut1/nobackup/tthbb/ttHbb_SPANet/spanet_output/classifier_btag_full_debug VENV_ACTIVATE=/uscms/home/sdurgut1/nobackup/tthbb/ttHbb_SPANet/SPANet/spanet_Env/bin/activate"

should_transfer_files = YES
when_to_transfer_output = ON_EXIT
transfer_executable = TRUE

+SingularityImage = "/cvmfs/unpacked.cern.ch/registry.hub.docker.com/cmsml/cmsml:latest"
+DesiredOS = "EL9"

# Smaller resource request for fast debug startup.
request_cpus = 4
request_memory = 24GB
request_disk = 20GB
request_GPUs = 1

output = logs/classifier_btag_full_debug/classifier_btag_full_debug_$(Cluster)_$(Process).out
error  = logs/classifier_btag_full_debug/classifier_btag_full_debug_$(Cluster)_$(Process).err
log    = logs/classifier_btag_full_debug/classifier_btag_full_debug_$(Cluster)_$(Process).log

queue 1
